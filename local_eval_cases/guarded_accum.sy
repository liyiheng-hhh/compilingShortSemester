// Guarded accumulation with unknown array guard (survives const fold).
int g[8];

int main() {
  int i = 0;
  while (i < 8) {
    g[i] = i + 1;
    i = i + 1;
  }
  int acc = 0;
  i = 0;
  while (i < 8) {
    if (g[i] > 4) {
      acc = acc + i;
    }
    i = i + 1;
  }
  putint(acc);
  putch(10);
  return 0;
}
