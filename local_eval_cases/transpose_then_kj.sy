// Transpose a into b, then reduce via a[k][j] (rewritable to b[j][k]).
int a[4][4];
int b[4][4];

int main() {
  int i = 0;
  while (i < 4) {
    int j = 0;
    while (j < 4) {
      a[i][j] = i * 4 + j + 1;
      j = j + 1;
    }
    i = i + 1;
  }
  i = 0;
  while (i < 4) {
    int j = 0;
    while (j < 4) {
      b[i][j] = a[j][i];
      j = j + 1;
    }
    i = i + 1;
  }
  int s = 0;
  i = 0;
  while (i < 4) {
    int j = 0;
    while (j < 4) {
      int k = 0;
      while (k < 4) {
        s = s + a[k][j];
        k = k + 1;
      }
      j = j + 1;
    }
    i = i + 1;
  }
  putint(s + b[0][0]);
  putch(10);
  return 0;
}
