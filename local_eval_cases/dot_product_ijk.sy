// Pure i-j-k dot product for LoopInterchange validation.
int C[32][32];
int A[32][32];

int main() {
  int T = 32;
  int i = 0;
  while (i < T) {
    int j = 0;
    while (j < T) {
      int k = 0;
      int sum = 0;
      while (k < T) {
        sum = sum + C[i][k] * A[k][j];
        k = k + 1;
      }
      A[i][j] = sum;
      j = j + 1;
    }
    i = i + 1;
  }
  return 0;
}
