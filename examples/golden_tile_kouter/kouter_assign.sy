int C[64][64];
int B[64][64];
int A[64][64];

int main() {
    int n = 64;
    int i;
    int j;
    int k;
    k = 0;
    while (k < n) {
        i = 0;
        while (i < n) {
            j = 0;
            while (j < n) {
                C[i][j] = C[i][j] + B[k][j];
                j = j + 1;
            }
            i = i + 1;
        }
        k = k + 1;
    }
    return 0;
}
