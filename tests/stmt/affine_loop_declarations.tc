int seed() {
    return 17;
}

int main() {
    int stride = seed();
    int i = 0;
    int x = 3;
    int y = 1;
    while (i < 5000) {
        int term = i * stride + 3;
        x = x + term;
        const int factor = 2;
        int twice = x * factor;
        int adjust = twice - i;
        y = y + adjust;
        i = i + 1;
    }
    return x + y + i;
}