int scale(int x) {
    int y = x + x;
    return y + 1;
}

int pick(int a, int b) {
    if (a > b) {
        return a;
    }
    return b;
}

int main() {
    int i = 0;
    int total = 0;
    while (i < 20) {
        total = total + scale(i) + pick(i, 3);
        i = i + 1;
    }
    return total;
}
